{
	"name": "JustHookUps",
	"private": true,
	"workspaces": [
		"apps/*",
		"packages/*"
	],
	"type": "module",
	"scripts": {
		"dev": "turbo dev --filter=server",
		"build": "turbo build",
		"flutter:dev": "cd apps/flutter_app && flutter run --dart-define=ENVIRONMENT=development --dart-define=API_BASE_URL=http://localhost:8787",
		"flutter:dev:android": "cd apps/flutter_app && flutter run --dart-define=ENVIRONMENT=development --dart-define=API_BASE_URL=http://10.0.2.2:8787",
		"flutter:preprod": "cd apps/flutter_app && flutter run --dart-define=ENVIRONMENT=preprod --dart-define=API_BASE_URL=https://dating-site-api.thabangsoulo.workers.dev",
		"flutter:prod": "cd apps/flutter_app && flutter run --dart-define=ENVIRONMENT=production --dart-define=API_BASE_URL=https://api.justhookups.dev",
		"flutter:build:apk:preprod": "cd apps/flutter_app && flutter build apk --release --dart-define=ENVIRONMENT=preprod --dart-define=API_BASE_URL=https://dating-site-api.thabangsoulo.workers.dev",
		"flutter:build:apk:prod": "cd apps/flutter_app && flutter build apk --release --dart-define=ENVIRONMENT=production --dart-define=API_BASE_URL=https://api.justhookups.dev",
		"check-types": "turbo check-types",
		"dev:server": "turbo -F server dev",
		"dev:alchemy": "turbo -F @JustHookUps/alchemy dev",
		"db:push": "turbo -F @JustHookUps/db db:push",
		"db:studio": "turbo -F @JustHookUps/db db:studio",
		"db:generate": "turbo -F @JustHookUps/db db:generate",
		"db:migrate": "turbo -F @JustHookUps/db db:migrate",
		"deploy": "turbo -F @JustHookUps/alchemy deploy",
		"destroy": "turbo -F @JustHookUps/alchemy destroy",
		"check": "biome check --write .",
		"env:check": "node --experimental-strip-types scripts/check-env.ts",
		"prepare": "husky"
	},
	"dependencies": {
		"@JustHookUps/env": "workspace:*",
		"dotenv": "catalog:",
		"zod": "catalog:"
	},

	"devDependencies": {
		"@JustHookUps/config": "workspace:*",
		"@biomejs/biome": "^2.2.0",
		"@cloudflare/workers-types": "catalog:",
		"@types/node": "catalog:",
		"turbo": "^2.8.12",
		"typescript": "catalog:",
		"husky": "^9.1.7"
	},
	"packageManager": "pnpm@10.28.2"
}
